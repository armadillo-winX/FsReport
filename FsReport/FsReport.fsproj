<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
	  <Authors>Mashiro Tamane</Authors>
	  <Product>FsReport</Product>
	  <Copyright>Copyright (c) 2026 $(Authors)</Copyright>
	  <Version>$(VersionPrefix)$(VersionSuffix)</Version>
	  <VersionPrefix>0.1.0</VersionPrefix>
	  <VersionSuffix>beta.1</VersionSuffix>
	  <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
	  <AssemblyName>fsreport</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Templates\ExampleTemplate.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Compile Include="PathInfo.fs" />
    <Compile Include="VersionInfo.fs" />
    <Compile Include="SettingsConfigurator.fs" />
    <Compile Include="TemplateFileHandler.fs" />
    <Compile Include="ReportFileHandler.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

</Project>
